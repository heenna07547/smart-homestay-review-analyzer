{
  "info": {
    "_postman_id": "d4c4d0b1-2610-0262-auth",
    "name": "AI Full Stack Auth API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseURL",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Heena\",\n  \"email\": \"heena@test.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseURL}}/api/auth/register",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "Login User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let response = pm.response.json();",
              "pm.environment.set(\"token\", response.token);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"heena@test.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseURL}}/api/auth/login",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Get All Reviews (Protected)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseURL}}/api/reviews",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "api",
            "reviews"
          ]
        }
      }
    },
    {
      "name": "Create Review (Protected)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"guestName\": \"Rahul\",\n  \"hotelName\": \"Mountain View Resort\",\n  \"review\": \"Excellent stay and great service\",\n  \"rating\": 5\n}"
        },
        "url": {
          "raw": "{{baseURL}}/api/reviews",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "api",
            "reviews"
          ]
        }
      }
    }
  ]
}